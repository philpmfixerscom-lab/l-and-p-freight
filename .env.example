# Public URL where users access the site (required for PWA manifest in production)
# Examples:
#   LP_APP_URL=https://dispatch.lpfreight.com
#   LP_APP_URL=https://your-app.onrender.com
LP_APP_URL=http://localhost

# Set to 1 when app is served at /app/ behind the nginx website (Docker deploy)
LP_WEB_MODE=0

# Persist database outside container (Docker sets /data automatically)
# LP_DATA_DIR=/data

# Docker: port for the marketing website + app proxy
WEB_PORT=80

# Optional Twilio SMS (also configurable in-app Settings)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=