# Public URL where users access the site (required for PWA + production)
# Examples:
#   LP_APP_URL=https://dispatch.lpfreight.com
#   LP_APP_URL=http://127.0.0.1:8502
LP_APP_URL=http://127.0.0.1:8502

# Set to 1 when app is served at /app/ behind the nginx website (Docker deploy)
LP_WEB_MODE=0

# Persist database outside container (Docker sets /data automatically)
# LP_DATA_DIR=/data

# Docker: ports for marketing website + HTTPS
WEB_PORT=80
WEB_SSL_PORT=443

# Production domain (for deploy scripts)
LP_SUBDOMAIN=dispatch.lpfreight.com
# SERVER_PUBLIC_IP=your.server.ip

# Optional Cloudflare tunnel fallback
# LP_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# Twilio SMS — also set in .streamlit/secrets.toml [twilio] section
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_DISPATCH_PHONE=+18284678218