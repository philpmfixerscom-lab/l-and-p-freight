# Copy to secrets.toml (gitignored) — never commit real credentials.
# Location: .streamlit/secrets.toml

[twilio]
account_sid = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
auth_token = "your_auth_token"
from_number = "+18285551234"
auto_send = "0"

[traccar]
url = "http://localhost:8082"
email = "admin"
password = "admin"
api_token = ""
device_id = ""

[smtp]
host = "smtp.gmail.com"
port = "587"
user = "your_email@gmail.com"
password = "your_app_password"
from_email = "your_email@gmail.com"

# L & P dispatch SMS contacts (your cell numbers — NOT 911)
# 911 / 988 / *47 / *477 are in the app as tap-to-call buttons (voice only)
[emergency]
dispatch_phone = "+18285550123"
phillip_phone = "+18285550124"
lawson_phone = "+18285550125"
auto_send = "1"