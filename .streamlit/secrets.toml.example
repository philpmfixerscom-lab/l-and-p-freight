# Copy to secrets.toml (gitignored) — never commit real credentials.
# Location: .streamlit/secrets.toml

[twilio]
account_sid = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
auth_token = "your_auth_token"
from_number = "+18285551234"
dispatch_phone = "+18284678218"
auto_send = "0"
auto_send_new_load = "1"

[traccar]
url = "http://localhost:8082"
email = "admin"
password = "admin"
api_token = ""
device_id = ""

[smtp]
host = "smtp.gmail.com"
port = "587"
user = "your_email@gmail.com"
password = "your_app_password"
from_email = "your_email@gmail.com"

# Driver emergencies: 911, 988, highway patrol, 511, hazmat, FMCSA, poison control
# are built into the app as tap-to-call buttons (Alerts tab + driver view).